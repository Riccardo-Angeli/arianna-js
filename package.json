{
  "name": "ariannajs",
  "version": "1.2.0",
  "description": "AriannA \u2014 Reactive UI framework. Performant like SolidJS, pleasant like React, native as the DOM.",
  "author": "Riccardo Angeli <riccardo.angeli@arianna.dev> (https://arianna.dev)",
  "license": "MIT",
  "type": "module",
  "main": "./core/index.ts",
  "module": "./core/index.ts",
  "types": "./core/index.ts",
  "bin": {
    "arianna": "./cli/arianna-cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./core/index.ts",
      "default": "./core/index.ts"
    },
    "./core": {
      "import": "./core/Core.ts"
    },
    "./observable": {
      "import": "./core/Observable.ts"
    },
    "./state": {
      "import": "./core/State.ts"
    },
    "./real": {
      "import": "./core/Real.ts"
    },
    "./virtual": {
      "import": "./core/Virtual.ts"
    },
    "./rule": {
      "import": "./core/Rule.ts"
    },
    "./stylesheet": {
      "import": "./core/Stylesheet.ts"
    },
    "./directive": {
      "import": "./core/Directive.ts"
    },
    "./context": {
      "import": "./core/Context.ts"
    },
    "./namespace": {
      "import": "./core/Namespace.ts"
    },
    "./jsx-runtime": {
      "import": "./core/jsx/jsx-runtime.ts"
    },
    "./jsx-dev-runtime": {
      "import": "./core/jsx/jsx-dev-runtime.ts"
    },
    "./components": {
      "import": "./components/index.ts"
    },
    "./additionals": {
      "import": "./additionals/index.ts"
    },
    "./config": {
      "import": "./arianna-config/arianna.config.ts"
    },
    "./components/audio": {
      "import": "./components/audio/index.ts"
    },
    "./components/video": {
      "import": "./components/video/index.ts"
    },
    "./components/composite": {
      "import": "./components/composite/index.ts"
    }
  },
  "files": [
    "core/",
    "components/",
    "additionals/",
    "types/",
    "arianna-config/",
    "cli/",
    "README.md",
    "LICENSE",
    "LICENSES/",
    "CHANGELOG.md",
    "package.json",
    "tsconfig.json"
  ],
  "keywords": [
    "framework",
    "ui",
    "reactive",
    "web-components",
    "custom-elements",
    "dom",
    "typescript",
    "state-management",
    "virtual-dom",
    "css-in-js",
    "tauri",
    "wasm",
    "svg",
    "mathml",
    "x3d",
    "observable",
    "pub-sub"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/riccardo-angeli/arianna"
  },
  "homepage": "https://arianna.dev",
  "bugs": {
    "url": "https://github.com/riccardo-angeli/arianna/issues",
    "email": "bugs@arianna.dev"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --out docs src/index.ts",
    "prepublish": "npm run typecheck",
    "bench": "node ./release/benchmarks/run.js",
    "build": "node scripts/build.mjs",
    "prepare": "husky || true",
    "build:min": "node scripts/build.mjs --minify"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "typedoc": "^0.25.0",
    "husky": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": [
    "./core/Namespace.ts"
  ],
  "funding": {
    "type": "commercial",
    "url": "https://arianna.dev/licensing"
  }
}
